# Puerto del servidor NestJS
PORT=3001

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Configuración SMTP MailHog para pruebas de envío de correos
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Retención de logs en días (0 = sin límite en lab)
LOG_RETENTION_DAYS=30
